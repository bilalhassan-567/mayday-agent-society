# Copy to agents/.env and fill in. The Watchman needs none of the LLM keys —
# only PATIENT_URL (+ optionally the log path). The rest is for the agents (Day 3+).

# --- Patient (target system) ---
PATIENT_URL=http://127.0.0.1:8000
# PATIENT_LOG_PATH=../patient/storage/logs/patient.log   # auto-detected if omitted

# --- Watchman patrol tuning (defaults come from /_watch/targets) ---
# PATROL_INTERVAL=5
# FAIL_THRESHOLD=2

# --- Incident / memory store ---
# Dev: local SQLite (default). Prod: point at ApsaraDB Postgres (PART 8).
# INCIDENT_DB=./data/mayday.sqlite

# --- LLM provider: BUILD on local, PROVE on Qwen (PLAN.md PART 0) ---
LLM_PROVIDER=local           # local | qwen
# local -> base_url=http://localhost:11434/v1                              model=qwen2.5:7b
# qwen  -> base_url=https://dashscope-intl.aliyuncs.com/compatible-mode/v1  model=qwen-max
# QWEN_KEY=
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Every Qwen Cloud model has its own 1M free-token pool; if the active model's
# pool is exhausted (403 FreeTierOnly), llm.py walks down this comma-separated
# chain (best first, Qwen-family only) and stays on the first model that works.
# QWEN_FALLBACK_MODELS=qwen3.7-max-2026-06-08,qwen3-max,qwen3.7-plus,qwen3.5-plus-2026-02-15

# --- Alibaba Cloud (Day 6) ---
# OSS_BUCKET=mayday-reports
# OSS_ENDPOINT=
# OSS_KEY_ID=
# OSS_KEY_SECRET=
